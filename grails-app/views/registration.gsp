<!doctype html>
<html>
<head>
    <meta name="layout" content="main"/>
    <title>Registration</title>
</head>
<body>


<div id="content" role="main">
    <h1>Registrarse</h1>

    <form action="/#" method="post">
        Email: <input type="email" name="userEmail" />
